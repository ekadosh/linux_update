# Copy this file to .env and fill in values for your Proxmox cluster.
# Secrets stay in .env; do not commit the real file.

# Proxmox API endpoint. PROXMOX_HOST may be a hostname or IP without scheme.
PROXMOX_URL=https://pve.example.lan:8006
PROXMOX_HOST=pve.example.lan
PROXMOX_PORT=8006
PROXMOX_VALIDATE_CERTS=false

# Proxmox API token. For proxmoxer, PROXMOX_TOKEN_ID is the token name
# portion, for example "ansible", not "user@realm!ansible".
PROXMOX_USER=ansible@pve
PROXMOX_TOKEN_ID=ansible
PROXMOX_TOKEN_SECRET=replace-me

# VM discovery filter.
PROXMOX_VM_TAG=ansible-update

# SSH settings for the Ubuntu guests.
ANSIBLE_SSH_USER=ansible
# ANSIBLE_PRIVATE_KEY_FILE=/Users/you/.ssh/ansible_ed25519

# SSH compatibility fallback for OpenSSH 9.x KEX stalls. Leave "auto" to test
# normal SSH first, then retry connectivity with compatibility options before
# the update playbook starts. Use "always" to force the workaround, or "never"
# to disable it.
SSH_COMPATIBILITY_MODE=auto
# SSH_COMPATIBILITY_ARGS=-o ControlMaster=auto -o ControlPersist=60s -o KexAlgorithms=curve25519-sha256 -o IPQoS=none

# Email alerts for update runs.
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_FROM=ansible-updates@domain.com
SMTP_RELAY_HOST=smtp.domain.com
SMTP_RELAY_PORT=587
SMTP_RELAY_STARTTLS=false
